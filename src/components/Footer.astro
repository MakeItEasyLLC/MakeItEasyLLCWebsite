---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-surface-lighter/50 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
            <div>
                <a href="/" class="no-underline text-text font-bold text-xl">
                    <span class="text-primary">Make</span><span>It</span><span class="text-accent">Easy</span>
                </a>
                <p class="mt-3 text-sm text-text-muted">Creating playful apps & cute products that bring joy to your day.</p>
            </div>
            <div>
                <h4 class="font-semibold text-text mb-3">Quick Links</h4>
                <ul class="space-y-2 text-sm text-text-muted">
                    <li><a href="/#services" class="no-underline hover:text-primary transition-colors">Services</a></li>
                    <li><a href="/#about" class="no-underline hover:text-primary transition-colors">About</a></li>
                    <li><a href="/#contact" class="no-underline hover:text-primary transition-colors">Contact</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-semibold text-text mb-3">Say Hello!</h4>
                <p class="text-sm text-text-muted">Have a fun project idea? Let's chat!</p>
                <a href="/#contact" class="btn btn-primary mt-3 text-sm no-underline">Contact Us</a>
            </div>
        </div>
        <div class="border-t border-surface-lighter/50 pt-8 text-center text-sm text-text-muted">
            <p>&copy; {currentYear} MakeItEasy LLC. All rights reserved.</p>
        </div>
    </div>
</footer>
